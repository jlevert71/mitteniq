generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SheetType {
  PLAN
  DETAIL
  NO_SCALE_NEEDED
  UNKNOWN
}

enum ScaleStatus {
  UNVERIFIED
  VERIFIED
  NO_SCALE_NEEDED
}

enum IntakeStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum UploadKind {
  DRAWING
  SPEC
}

enum UploadStatus {
  PENDING
  UPLOADED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects Project[]
}

model Project {
  id        String   @id @default(cuid())
  name      String

  // PHASE 2: required
  ownerId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  uploads Upload[]
}

model Upload {
  id        String       @id @default(cuid())
  projectId String
  kind      UploadKind
  filename  String
  r2Key     String
  sizeBytes Int
  mimeType  String
  status    UploadStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Intake v1 fields
  pageCount    Int?
  isSearchable Boolean?
  isRasterOnly Boolean?
  intakeReport Json?
  intakeStatus IntakeStatus @default(PENDING)
  intakeStage  String?
  /// Plain-English hint while PROCESSING (why intake may take longer)
  intakeDelayReason String?
  intakeError  String?

  sheets Sheet[]
  preBidChecklist PreBidChecklist?
}

model Sheet {
  id                  String      @id @db.Text
  uploadId            String
  pageNumber          Int

  // Drawing identity
  sheetNumber         String?
  sheetName           String?
  discipline          String?

  // Mixed-content / spec identity
  pageClass           String?     // DRAWING | SPEC | BID | GENERAL | UNKNOWN
  sectionNumber       String?
  sectionTitle        String?
  isElectricalRelated Boolean?

  sheetType           SheetType
  scaleStatus         ScaleStatus
  scaleConfidence     Int
  notes               String?

  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@unique([uploadId, pageNumber])
}

model PreBidChecklist {
  id          String   @id @default(cuid())
  uploadId    String   @unique
  extractedAt DateTime
  passesRun   Int
  pagesScanned Int
  model       String
  durationMs  Int

  // Section 1 — Bid Identity
  projectName         String?
  bidDueDate          String?
  bidDueTime          String?
  bidOpeningType      String?
  biddingTo           String?
  deliverBidTo        String?
  deliveryMethod      String?
  numberOfCopies      Int?
  documentsAvailableAt String?
  lastRfiDate         String?

  // Section 2 — Pre-Bid Meeting
  preBidHeld          Boolean?
  preBidMandatory     Boolean?
  preBidMandatoryScope String?
  preBidDate          String?
  preBidTime          String?
  preBidLocation      String?

  // Section 3 — Schedule
  proposedStartDate      String?
  proposedCompletionDate String?

  // Section 4 — Bid Pricing Format
  unitPricing        Boolean?
  alternates         Boolean?
  alternatesCount    Int?
  alternatesDescription String?
  allowances         Boolean?
  breakDownsRequired Boolean?

  // Section 5 — Bonds & Insurance
  bidBondRequired        Boolean?
  bidBondAmount          String?
  plmBonds               Boolean?
  liquidatedDamages      Boolean?
  liquidatedDamagesAmount String?
  obligee                String?
  specialInsuranceRequired Boolean?
  specialInsuranceType   String?

  // Section 6 — Compliance & Labor
  certifiedPayroll Boolean?
  buyAmerican      Boolean?
  dbeSbeRequired   Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload         Upload                       @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  allowanceItems PreBidChecklistAllowanceItem[]
}

model PreBidChecklistAllowanceItem {
  id          String @id @default(cuid())
  checklistId String
  sortOrder   Int
  description String
  amount      String

  createdAt DateTime @default(now())

  checklist PreBidChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}